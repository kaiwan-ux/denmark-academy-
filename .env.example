APP_ENV=local
APP_NAME=Denmark Academy
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/denmark_academy

# Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Cache
REDIS_URL=redis://localhost:6379/0

# Object Storage
OBJECT_STORAGE_DRIVER=local
LOCAL_OBJECT_STORAGE_PATH=/data/object-storage

# Embedding Configuration
EMBEDDING_DIMENSION=384
EMBEDDING_PROVIDER=placeholder
PARSER_VERSION=pdf-parser-v1

# AI Provider Configuration
AI_PRIMARY_PROVIDER=grok
AI_FALLBACK_PROVIDER=grok
AI_REQUEST_TIMEOUT_SECONDS=60

# SECURITY: Add your API keys below. Never commit real keys to version control.
# Multiple Grok API Keys (Load Balanced) - Add 3-6 keys for better performance
GROK_API_KEY_1=your_grok_key_1_here
GROK_API_KEY_2=your_grok_key_2_here
GROK_API_KEY_3=your_grok_key_3_here
GROK_API_KEY_4=your_grok_key_4_here
GROK_API_KEY_5=your_grok_key_5_here
GROK_API_KEY_6=your_grok_key_6_here
GROK_BASE_URL=https://api.groq.com/openai/v1
GROK_MODEL=llama-3.3-70b-versatile

# Gemini API Keys (Optional)
GEMINI_API_KEY_1=your_gemini_key_1_here
GEMINI_API_KEY_2=your_gemini_key_2_here
GEMINI_API_KEY_3=your_gemini_key_3_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

# Current Affairs Feature
CURRENT_AFFAIRS_SCHEDULER_ENABLED=false
CURRENT_AFFAIRS_MAX_ARTICLES_PER_RUN=3

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# Admin Endpoint Security
ADMIN_API_KEY=your_secure_admin_key_here
